# ============================================================================
# AMAN (Inventarisasi BMN) — .gitignore
# ============================================================================

# ----- Node / frontend dependencies -----
node_modules/
/.pnp
.pnp.js
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ----- Python / backend -----
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
venv/
.venv/
backend/venv/
.pytest_cache/
.mypy_cache/

# ----- Builds -----
/build
frontend/build/
/out
dist/
*.tsbuildinfo

# ----- Environment & secrets (NEVER commit) -----
.env
.env.*
*.env
*.pem
*.key
credentials.json
*credentials*.json
.credentials

# ----- Test artifacts / tooling output -----
/coverage
test_reports/
.emergent/
memory/test_credentials.md

# ----- Runtime uploads (keep only the bundled default logo) -----
/backend/uploads/*
!/backend/uploads/logos
/backend/uploads/logos/*
!/backend/uploads/logos/default_logo.png

# ----- Editors / OS -----
.idea/
.vscode/
.DS_Store

# ----- Logs / misc -----
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
dump.rdb
